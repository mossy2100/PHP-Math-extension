// Windows build configuration for the math extension.

ARG_ENABLE("math", "enable OceanMoon math support", "no");

if (PHP_MATH != "no") {
  EXTENSION("math", "math.c floats.c Complex/complex.c Complex/complex_conversion.c Complex/complex_inspection.c Complex/complex_comparison.c");
  AC_DEFINE("HAVE_MATH", 1, "OceanMoon math support");
}
