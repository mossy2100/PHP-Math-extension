#!/usr/bin/env bash
#
# Copy the built modules/oceanmoon_math.so into PHP's own extension_dir, so it's available to be
# loaded by bare filename (e.g. `extension=oceanmoon_math.so` in php.ini, or `-d
# extension=oceanmoon_math.so` on the command line) rather than needing a full path every time.
#
# This is separate from `composer enable` (scripts/global-install), which points a conf.d ini
# file directly at modules/oceanmoon_math.so in this repo and so doesn't strictly need a deploy
# step -- but other tools/invocations that expect the module to already be sitting in the
# standard extension_dir under its bare name still need this.
#
# Usage:
#   scripts/deploy   # composer deploy
#
set -euo pipefail

cd "$(dirname "$0")/.."

MODULE="modules/oceanmoon_math.so"

if [[ ! -f "$MODULE" ]]; then
    echo "$MODULE not found -- run 'composer make' first." >&2
    exit 1
fi

EXT_DIR="$(php -r 'echo ini_get("extension_dir");')"

if [[ -z "$EXT_DIR" ]]; then
    echo "Could not determine PHP's extension_dir." >&2
    exit 1
fi

mkdir -p "$EXT_DIR"
cp "$MODULE" "$EXT_DIR/"
echo "Deployed: $MODULE -> $EXT_DIR/oceanmoon_math.so"
