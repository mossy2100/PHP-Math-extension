#!/usr/bin/env bash
#
# Run PHPStan static analysis at a given level, optionally restricted to a path.
#
# Usage:
#   scripts/analyze            # level 9 (default), default paths (from phpstan.neon)
#   scripts/analyze 5          # level 5, default paths
#   scripts/analyze tests/_dev # level 9, path "tests/_dev"
#   scripts/analyze 5 tests/_dev
#
set -euo pipefail

cd "$(dirname "$0")/.."

level=9
path=""

if [[ $# -eq 1 ]]; then
    if [[ "$1" =~ ^[0-9]+$ ]]; then
        level="$1"
    else
        path="$1"
    fi
elif [[ $# -ge 2 ]]; then
    level="$1"
    path="$2"
fi

if [[ -n "$path" ]]; then
    exec vendor/bin/phpstan analyze -l "$level" "$path"
else
    exec vendor/bin/phpstan analyze -l "$level"
fi
